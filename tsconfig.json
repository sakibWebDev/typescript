{
  "compilerOptions": {
    "target": "ES6",
    "module": "CommonJS",
    "rootDir": "./src",
    "outDir": "./dist",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src"],   // 👈 only src compile হবে
  "exclude": [
    "node_modules",
    "dist",
    "prisma",
    "prisma.config.ts"
  ]
}